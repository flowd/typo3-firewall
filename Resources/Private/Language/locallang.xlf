      <trans-unit id="examples.table.header_exact.target.prefix">
        <source>Target:</source>
      </trans-unit>
      <trans-unit id="examples.table.header_exact.description">
        <source>Blocks requests where the User-Agent header is exactly this value. The header name goes into the target field; the expected value into the value field.</source>
