        <source>Path (exact match)</source>
      </trans-unit>
      <trans-unit id="examples.table.path_exact.value">
        <source>/admin/login</source>
      </trans-unit>
      <trans-unit id="examples.table.path_exact.description">
        <source>Blocks requests where the path matches exactly /admin/login.</source>
      </trans-unit>
      <trans-unit id="examples.table.path_regex.kind">
        <source>Path (regular expression)</source>
      </trans-unit>
      <trans-unit id="examples.table.path_regex.value">
        <source>/^\/api\/v[0-9]+\/private\/.*/</source>
      </trans-unit>
      <trans-unit id="examples.table.path_regex.description">
        <source>Blocks requests where the path matches the given regular expression.</source>
      </trans-unit>
      <trans-unit id="examples.table.header_exact.kind">
        <source>HTTP header equals value</source>
      </trans-unit>
      <trans-unit id="examples.table.header_exact.value">
        <source>curl/7.68.0</source>
