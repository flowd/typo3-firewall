parameters:
	ignoreErrors:
		# FileArrayPatternBackend has validation logic that increases complexity
		# but is clearer as a single class than split across multiple
		-
			identifier: complexity.classLike
			count: 1
			path: ../../Classes/Pattern/FileArrayPatternBackend.php

		# FileArrayWriter has file I/O logic that increases complexity
		-
			identifier: complexity.classLike
			count: 1
			path: ../../Classes/Writer/FileArrayWriter.php
